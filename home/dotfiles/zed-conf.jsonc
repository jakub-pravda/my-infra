{
  "disable_ai": false,

  "base_keymap": "VSCode",

  "vim_mode": true,
  "helix_mode": true,

  "autosave": {
    "after_delay": {
      "milliseconds": 2000
    }
  },

  "assistant": {
    "enabled": false
  },

  "edit_predictions": {
    "provider": "none"
  },

  "show_edit_predictions": false,

  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },

  "telemetry": {
    "metrics": false
  },

  "ui_font_size": 24,
  "buffer_font_size": 18,

  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "VSCode Dark Modern"
  },

  "lsp": {
    "metals": {
      "settings": {
        "inlayHints": {
          "inferredTypes": {
            "enable": true
          }
        }
      }
    }
  }
}
